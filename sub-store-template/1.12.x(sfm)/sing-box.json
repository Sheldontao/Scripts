{
  "log": {
    "level": "info",
    "output": "sing-box.log",
    "timestamp": true
  },
  "ntp": {
    "enabled": true,
    "server": "ntp.aliyun.com",
    "server_port": 123,
    "interval": "30m"
  },
  "dns": {
    "servers": [
      {
        "type": "tls",
        "tag": "dns_proxy",
        "server": "8.8.8.8"
      },
      {
        "type": "local",
        "tag": "local"
      },
      {
        "type": "udp",
        "tag": "dns_direct",
        "server": "223.5.5.5"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "server": "local"
      },
      {
        "clash_mode": "Global",
        "server": "fakeip"
      },
      {
        "domain_suffix": [".local", ".lan", "miwifi.com"],
        "server": "local"
      },
      {
        "rule_set": "ads",
        "action": "predefined"
      },
      {
        "domain_suffix": [
          "tplogin.cn",
          "router.asus.com",
          "tendawifi.com",
          "tplinkwifi.net",
          "app-measurement.com",
          "hm.baidu.com",
          "firebaselogging.googleapis.com",
          "firebaselogging-pa.googleapis.com",
          "beacons.gvt2.com",
          "beacons2.gvt2.com",
          "beacons3.gvt2.com",
          "tracking.miui.com",
          "market.xiaomi.com",
          "lancache.steamcontent.com"
        ],
        "rule_set": [
          "cn_domain",
          "apple_cn",
          "microsoft_cn",
          "bilibili_domain"
        ],
        "server": "dns_direct"
      },
      {
        "process_name": [
          "motrixnext-aria2c",
          "aria2c.exe",
          "fdm.exe",
          "folx.exe",
          "nettransport.exe",
          "thunder.exe",
          "transmission.exe",
          "utorrent.exe",
          "webtorrent.exe",
          "webtorrent helper.exe",
          "qbittorrent.exe",
          "downloadservice.exe",
          "weiyun.exe",
          "baidunetdisk.exe"
        ],
        "server": "dns_direct"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": ["proxy_domain"],
            "invert": true
          },
          {
            "rule_set": "cn_ip"
          }
        ],
        "server": "dns_direct"
      },
      {
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      }
    ],
    "independent_cache": true,
    "client_subnet": "222.17.11.0/24"
  },
  "inbounds": [
    {
      "type": "tun",
      "address": ["172.19.0.1/30", "fdfe:dcba:9876::0/126"],
      "auto_route": true,
      "stack": "mixed",
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 7890
        }
      }
    },
    {
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "type": "selector",
      "outbounds": [
        "direct",
        "hk-auto",
        "tw-auto",
        "jp-auto",
        "sg-auto",
        "us-auto",
        "all",
        "noCN-auto"
      ],
      "default": "hk-auto"
    },
    {
      "tag": "google",
